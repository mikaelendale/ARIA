OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT=30

# Twilio — https://console.twilio.com/ → Account Info (Account SID + Auth Token)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
# SMS "From" — your Twilio phone number in E.164, e.g. +15551234567 (Console → Phone numbers)
TWILIO_PHONE_NUMBER=
# WhatsApp "From" — e.g. whatsapp:+14155238886 (sandbox) or whatsapp:+1yourtwilionumber (primary channel for v1)
TWILIO_WHATSAPP_FROM=
# Voice / Media Streams (Hermes) — future release; leave empty for WhatsApp-only. Inbound voice webhook says "use WhatsApp" + hangup.
TWILIO_MEDIA_STREAM_URL=

# Verify credentials (no charge): php artisan twilio:ping
# Optional test send (uses trial credit / may require verified recipient on trial):
#   php artisan twilio:ping --sms=+15551234567
#   php artisan twilio:ping --whatsapp=+15551234567

# Demo-only POST /api/trigger/scenario (set true only for hackathons)
ARIA_DEMO_TRIGGERS=false

# Public /guest/voice — Hermes WhatsApp panel calls send_whatsapp to this guest UUID only (seed a guest, paste id).
GUEST_KIOSK_WHATSAPP_GUEST_ID=

# Kitchen room-service board (no staff login): open once as /kitchen?token=... then refresh works in that browser.
ARIA_KITCHEN_DISPLAY_TOKEN=
# Optional: auto-refresh seconds for the kitchen page (minimum 5)
# ARIA_KITCHEN_POLL_SECONDS=15

OPENWEATHER_KEY=
GOOGLE_PLACES_KEY=
AVIATIONSTACK_KEY=

# Hermes voice (OpenAI Realtime — optional; see config/hermes.php)
HERMES_REALTIME_MODEL=
HERMES_REALTIME_URL=
