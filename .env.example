APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:L4EgLjvkf3RYsRNJhdpmLiLTZu5qNCP5vMUN6nCD8zc=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# After migrate --seed: operator logins (password: password) — gm@aria.local, ops@aria.local,
# manager@aria.local, reception@aria.local, viewer@aria.local. New registrations default to viewer.

